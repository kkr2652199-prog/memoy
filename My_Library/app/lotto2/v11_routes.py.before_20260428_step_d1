@router.get("/stats/comprehensive")
async def api_v11_stats_comprehensive():
    """V11 종합 통계 (1군 stats/comprehensive 형식 호환).

    lotto_draws는 공유이므로 1군과 동일한 응답 가능.
    """
    from app.lotto2.models import get_lotto2_db
    from collections import Counter
    from itertools import combinations

    conn = get_lotto2_db()
    try:
        rows = conn.execute("SELECT * FROM lotto_draws ORDER BY draw_no").fetchall()
        if not rows:
            return {
                "total_draws": 0,
                "latest_draw": 0,
                "latest_date": "",
                "frequency": {},
                "pair_frequency": [],
                "range_distribution": {},
                "odd_even": {},
                "sum_range": {},
                "consecutive": {},
            }

        freq = Counter()
        pair_freq = Counter()
        range_dist = Counter()
        odd_even = Counter()
        sum_list = []
        consec_list = []

        for r in rows:
            nums = sorted([r["num1"], r["num2"], r["num3"], r["num4"], r["num5"], r["num6"]])
            for x in nums:
                freq[x] += 1
                if x <= 10:
                    range_dist["1-10"] += 1
                elif x <= 20:
                    range_dist["11-20"] += 1
                elif x <= 30:
                    range_dist["21-30"] += 1
                elif x <= 40:
                    range_dist["31-40"] += 1
                else:
                    range_dist["41-45"] += 1

            odds = sum(1 for x in nums if x % 2 == 1)
            odd_even[f"{odds}홀{6-odds}짝"] += 1

            sum_list.append(sum(nums))

            consec = sum(1 for i in range(5) if nums[i + 1] - nums[i] == 1)
            consec_list.append(consec)

            for p in combinations(nums, 2):
                pair_freq[p] += 1

        latest = rows[-1]
        sum_avg = sum(sum_list) / len(sum_list)
        return {
            "total_draws": len(rows),
            "latest_draw": latest["draw_no"],
            "latest_date": latest["draw_date"] or "",
            "frequency": {str(k): v for k, v in freq.most_common()},
            "pair_frequency": [
                {"pair": f"{a},{b}", "count": v} for (a, b), v in pair_freq.most_common(30)
            ],
            "range_distribution": dict(range_dist),
            "odd_even": dict(odd_even),
            "sum_range": {"min": min(sum_list), "max": max(sum_list), "avg": round(sum_avg, 2)},
            "consecutive": {
                "avg": round(sum(consec_list) / len(consec_list), 3),
                "distribution": dict(Counter(consec_list)),
            },
        }
    finally:
        conn.close()

