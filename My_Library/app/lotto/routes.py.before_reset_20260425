@router.get("/dashboard/summary")
async def api_dashboard_summary():
    """메인 대시보드용 요약: 다음 회차, 최근 50회 핫번호 TOP5, 등수 분포."""
    from app.lotto.models import get_lotto_db

    conn = get_lotto_db()
    try:
        max_row = conn.execute("SELECT MAX(draw_no) FROM lotto_draws").fetchone()[0]
        max_draw = int(max_row) if max_row is not None else 0
        next_no = max_draw + 1
        hot_top = _dashboard_hot_numbers(conn, 50, 5) if max_draw > 0 else []

        floor_draw = max(0, max_draw - 200)
        rank_row = conn.execute(
            """
            SELECT
              COALESCE(SUM(CASE WHEN matched_count = 6 THEN 1 ELSE 0 END), 0) AS r1,
              COALESCE(SUM(CASE WHEN matched_count = 5 AND bonus_matched = 1 THEN 1 ELSE 0 END), 0) AS r2,
              COALESCE(SUM(CASE WHEN matched_count = 5 AND bonus_matched = 0 THEN 1 ELSE 0 END), 0) AS r3,
              COALESCE(SUM(CASE WHEN matched_count = 4 THEN 1 ELSE 0 END), 0) AS r4,
              COALESCE(SUM(CASE WHEN matched_count = 3 THEN 1 ELSE 0 END), 0) AS r5
            FROM lotto_predictions
            WHERE matched_count >= 0
              AND target_draw_no >= ?
            """,
            (floor_draw,),
        ).fetchone()
        r1, r2, r3, r4, r5 = (int(rank_row[i] or 0) for i in range(5))
        return {
            "next_draw_no": next_no,
            "hot_numbers": hot_top,
            "rank_distribution": {
                "rank1": r1,
                "rank2": r2,
                "rank3": r3,
                "rank4": r4,
                "rank5": r5,
            },
        }
    finally:
        conn.close()


@router.get("/predictions")
async def api_predictions(limit: int = 20):
    """예측 이력 조회."""
    from app.lotto.models import get_lotto_db

    conn = get_lotto_db()
    rows = conn.execute(
        """SELECT p.*, d.num1 AS actual_1, d.num2 AS actual_2, d.num3 AS actual_3,
                  d.num4 AS actual_4, d.num5 AS actual_5, d.num6 AS actual_6, d.bonus AS actual_bonus
           FROM lotto_predictions p
           LEFT JOIN lotto_draws d ON p.target_draw_no = d.draw_no
           ORDER BY p.created_at DESC LIMIT ?""",
        (limit,),
    ).fetchall()
    conn.close()
    return {"predictions": [dict(r) for r in rows]}
