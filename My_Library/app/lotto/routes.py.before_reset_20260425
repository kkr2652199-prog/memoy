@router.get("/predict/latest/{draw_no}")
async def api_predict_latest(draw_no: int):
    """저장된 예측만 조회 (POST 재실행 없음)."""
    from app.lotto.models import get_lotto_db

    conn = get_lotto_db()
    try:
        rows = conn.execute(
            """
            SELECT brain_tag, method, num1, num2, num3, num4, num5, num6,
                   confidence, reasoning
            FROM lotto_predictions
            WHERE target_draw_no = ?
            ORDER BY confidence DESC, brain_tag
            """,
            (draw_no,),
        ).fetchall()
        preds: list[dict] = []
        for r in rows:
            d = dict(r)
            tag = _prediction_row_brain_tag(d)
            preds.append(
                {
                    "brain_tag": tag,
                    "nums": [d["num1"], d["num2"], d["num3"], d["num4"], d["num5"], d["num6"]],
                    "confidence": d["confidence"],
                    "reasoning": d.get("reasoning") or "",
                }
            )
        return {"draw_no": draw_no, "predictions": preds, "count": len(preds)}
    finally:
        conn.close()


