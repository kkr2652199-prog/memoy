import os
import sys
import webbrowser
import threading
from pathlib import Path

import uvicorn
from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from fastapi.staticfiles import StaticFiles
from fastapi.responses import FileResponse

from app.db.database import init_db
from app.config import RAW_MATERIALS_DIR
from app.api.routes_ingest import router as ingest_router
from app.api.routes_library import router as library_router
from app.api.routes_graph import router as graph_router
from app.api.routes_chat import router as chat_router
from app.api.routes_project import router as project_router
from app.api.routes_settings import router as settings_router
from app.api.routes_knowledge import router as knowledge_router
from app.lotto.routes import router as lotto_router
from app.lotto2.routes import router as lotto2_router

import logging

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s %(name)s %(levelname)s %(message)s",
)

app = FastAPI(title="나의 지식 도서관", version="0.1.0")

# LAN 개발용 CORS: 루프백 + RFC 1918 사설 IPv4 Origin만 (포트 선택). 공인 인터넷 전면 개방 아님.
_ALLOW_ORIGIN_REGEX = (
    r"https?://("
    r"localhost|127\.0\.0\.1|"
    r"192\.168\.\d{1,3}\.\d{1,3}|"
    r"10\.\d{1,3}\.\d{1,3}\.\d{1,3}|"
    r"172\.(?:1[6-9]|2[0-9]|3[0-1])\.\d{1,3}\.\d{1,3}"
    r")(?::\d+)?$"
)
# 미리보기·Live Server·같은 Wi‑Fi의 다른 기기(사설 IP)에서 API 호출 시 Origin 허용
app.add_middleware(
    CORSMiddleware,
    allow_origin_regex=_ALLOW_ORIGIN_REGEX,
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

STATIC_DIR = Path(__file__).parent / "static"

app.include_router(ingest_router)
app.include_router(library_router)
app.include_router(graph_router)
app.include_router(chat_router)
app.include_router(project_router)
app.include_router(settings_router)
app.include_router(knowledge_router)
app.include_router(lotto_router)
app.include_router(lotto2_router)

app.mount("/static", StaticFiles(directory=str(STATIC_DIR)), name="static")

RAW_MATERIALS_DIR.mkdir(parents=True, exist_ok=True)
app.mount("/raw", StaticFiles(directory=str(RAW_MATERIALS_DIR)), name="raw_materials")


@app.get("/")
async def root():
    return FileResponse(str(STATIC_DIR / "index.html"))

@app.on_event("startup")
async def startup():
    init_db()
    from app.lotto.models import init_lotto_db

    init_lotto_db()
    from app.lotto2.models import init_lotto2_db

    init_lotto2_db()

    from app.config import get_value
    if get_value("scheduler.enabled"):
        from app.core.scheduler import start_scheduler
        interval = get_value("scheduler.interval_hours", 24)
        start_scheduler(interval_hours=interval)


@app.on_event("shutdown")
async def shutdown():
    from app.core.scheduler import stop_scheduler
    stop_scheduler()


def open_browser(port: int):
    webbrowser.open(f"http://localhost:{port}")


def main():
    bind_host = os.environ.get("APP_BIND_HOST", "127.0.0.1")
    try:
        port = int(os.environ.get("APP_PORT", "8123"))
    except ValueError:
        port = 8123

    timer = threading.Timer(1.5, lambda: open_browser(port))
    timer.daemon = True
    timer.start()

    uvicorn.run(
        "app.main:app",
        host=bind_host,
        port=port,
        reload=False,
        log_level="info",
    )


if __name__ == "__main__":
    sys.path.insert(0, str(Path(__file__).resolve().parent.parent))
    main()
